# Backend API URL (Vite frontend — clinic data)
VITE_API_URL=http://localhost:8000

# Gemini AI (server-side only — never use VITE_ prefix)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# Production Express server port (npm run server after npm run build)
CHAT_SERVER_PORT=8787
PORT=8787

# Optional: public site URL for metadata
APP_URL="http://localhost:3000"
