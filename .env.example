# Backend API URL (Vite frontend — clinic data)
VITE_API_URL=http://localhost:8000

# DeepSeek AI (server-side only — never use VITE_ prefix)
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
DEEPSEEK_MODEL="deepseek-chat"

# Rasm tahlili (DeepSeek rasm qabul qilmaydi — alohida vision API kerak)
# Google AI Studio dan bepul: https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# yoki OpenAI- mos vision:
# VISION_API_KEY="sk-..."
# VISION_BASE_URL="https://api.openai.com/v1"
# VISION_MODEL="gpt-4o-mini"
# DEEPSEEK_API_BASE="https://api.deepseek.com"

# Production Express server port (npm run server after npm run build)
CHAT_SERVER_PORT=8787
PORT=8787

# Optional: public site URL for metadata
APP_URL="http://localhost:3000"
